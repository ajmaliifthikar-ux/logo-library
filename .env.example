# LogoLibrary Environment Variables
# Copy this to .env and fill in your values

# Figma API Token (for extracting logos from Figma files)
# Get yours at: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=your_figma_token_here

# Cloudinary Credentials (for CDN sync)
CLOUDINARY_CLOUD_NAME=dldf3xftp
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: GitHub Token for auto-pushing updates
# GITHUB_TOKEN=your_github_token_here
